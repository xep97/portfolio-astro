---

<Layout title="Portfolio">
	<div class="lang-switcher">
    	<button data-lang="no" class="lang-btn active">NO</button>
    	<button data-lang="en" class="lang-btn">EN</button>
  	</div>
  <main class="container">
    
    <section class="hero">
      <span class="badge" data-key="badge">{translations.no.badge}</span>
      <h1>
        <span data-key="heroTitle">{translations.no.heroTitle}</span> 
        <em data-key="heroEm">{translations.no.heroEm}</em>
      </h1>
      <h3 data-key="heroSub1">{translations.no.heroSub1}</h3>
      <h3 data-key="heroSub2">{translations.no.heroSub2}</h3>
      <h3 data-key="heroSub3">{translations.no.heroSub3}</h3>
      <a class="cta" href="#contact" data-key="heroCta">{translations.no.heroCta}</a>
    </section>

    <section class="skills">
		<h2 class="section-label" data-key="labelMuch">{translations.no.labelMuch}</h2>
      	<div class="skill-grid">
        	{skills.map(skill => <span class="card skill-tag">{skill}</span>)}
      	</div>
	</section>

    <section class="skills">
		<h2 class="section-label" data-key="labelLittle">{translations.no.labelLittle}</h2>
      	<div class="skill-grid">
        	{second_skills.map(second_skill => <span class="card skill-tag">{second_skill}</span>)}
      	</div>
    </section>

    <section class="projects">
		<h2 class="section-label">Prosjekter</h2>
		<div class="project-grid">
			{projects.map(project => (
				<a href={project.link} class="card project-card" data-tags={project.tags?.join(',')}>
				<h3>{project.title}</h3>
				<p>{project.desc}</p>
				
				<div class="project-tags-inline">
					{project.tags?.map(tag => <small class="mini-tag">{tag}</small>)}
				</div>
				</a>
			))}
		</div>
	</section>

    <section id="contact" class="contact">
      <h2>Kontakt meg</h2>
      <a href="mailto:egil97.dev@gmail.com" class="cta">Send meg en mail</a>
      <a href="https://github.com/xep97" class="cta">Github</a>
    </section>

  </main>
</Layout>


<script>
  const buttons = document.querySelectorAll('.skill-tag');
  const projects = document.querySelectorAll('.project-card');

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const selectedSkill = button.textContent.trim();
      const isAlreadyActive = button.classList.contains('active-filter');

      // 1. Reset all buttons and show all projects first
      buttons.forEach(btn => btn.classList.remove('active-filter'));
      projects.forEach(proj => (proj as HTMLElement).style.display = 'flex');

      // 2. If it wasn't already active, apply the filter
      if (!isAlreadyActive) {
        button.classList.add('active-filter');
        
        projects.forEach(project => {
          const projectTags = project.getAttribute('data-tags') || "";
          if (!projectTags.split(',').includes(selectedSkill)) {
            (project as HTMLElement).style.display = 'none';
          }
        });
      }
    });
  });


  
</script>

<script>
  // ... your existing skill filter code ...

  // Language Logic
 const translations = {
	no: {
		heroTitle: "Hei",
		heroEm: "verden",
		heroSub1: "Mitt navn er Egil og jeg lager nettsider",
		heroSub2: "Jeg er 28 år og bor på Sunnmøre i Norge",
		heroSub3: "Jeg har laget nettsider just for fun på fritiden i 15 år",
		heroCta: "Ta gjerne kontakt",
		labelMuch: "Har jobbet mye med",
		labelLittle: "Har også erfaring med",
		labelProjects: "Prosjekter",
		contactTitle: "Kontakt meg",
		contactCta: "Send meg en mail",
		badge: "Tilgjengelig for arbeid"
	},
	en: {
		heroTitle: "Hello",
		heroEm: "World",
		heroSub1: "My name is Egil and I make websites",
		heroSub2: "I am 28 years old and live in Sunnmøre, Norway",
		heroSub3: "I've been building websites for fun in my spare time for 15 years",
		heroCta: "Get in touch",
		labelMuch: "Experienced with",
		labelLittle: "Familiar with",
		labelProjects: "Projects",
		contactTitle: "Contact me",
		contactCta: "Send me an email",
		badge: "Available for work"
	}
	};

  const langButtons = document.querySelectorAll('.lang-btn');
  const translatableElements = document.querySelectorAll('[data-key]');

  langButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.getAttribute('data-lang');
      
      // Update buttons UI
      langButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Update text
      translatableElements.forEach(el => {
        const key = el.getAttribute('data-key');
        el.textContent = translations[lang][key];
      });
    });
  });
</script>