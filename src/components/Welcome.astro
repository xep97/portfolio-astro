---
import macbook from '../assets/macbookz.png';

import screen_chat from '../assets/screen_chat.png';
import screen_math from '../assets/screen_math.png';
import screen_reminders from '../assets/screen_reminders.png';
import screen_timepost from '../assets/screen_timepost.png';
import screen_yatzt from '../assets/screen_yatzy.png';

const images = [
  { src: screen_chat.src, alt: "Chat Screen" },
  { src: screen_math.src, alt: "Math Screen" },
  { src: screen_reminders.src, alt: "Reminders Screen" },
  { src: screen_timepost.src, alt: "Timepost Screen" },
  { src: screen_yatzt.src, alt: "Yatzy Screen" }
];
---

<div id="macbook">
	<div id="macbook_screen">
		<div class="screen-container">
			<div class="screen-wrapper">
				{images.map((img, index) => (
				<img 
					src={img.src} 
					alt={img.alt} 
					class="portfolio-screen" 
					data-active={index === 0 ? "true" : "false"}
				/>
				))}
			</div>
		</div>
	</div>
	<img id="macbook_body" src={macbook.src} alt="" fetchpriority="high" />
</div>

<style>
	#macbook {
		width: 100%;
		position: relative;
	}
	#macbook_body {
		width: 100%;
		z-index: 400000;

	}
	#macbook_screen {
		position: absolute;
		bottom: -10%;
		left: 10%;
		width: 80%;
		aspect-ratio: 5/4;
		z-index: 3;
	}



	.screen-wrapper {
    position: relative;
    width: 100%;
    /* Replace with your mockup dimensions */
    aspect-ratio: 16 / 10; 
    overflow: hidden;
  }

  .portfolio-screen {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    
    /* Smooth fade transition */
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
  }

  /* Only show the image marked as active */
  .portfolio-screen[data-active="true"] {
    opacity: 1;
    z-index: 10;
  }
</style>

<script>
  function initGallery() {
    const images = document.querySelectorAll('.portfolio-screen');
    let currentIndex = 0;

    function nextImage() {
      // Set current to false
      images[currentIndex].setAttribute('data-active', 'false');

      // Calculate next index
      currentIndex = (currentIndex + 1) % images.length;

      // Set next to true
      images[currentIndex].setAttribute('data-active', 'true');
    }

    // Run every 5000ms (5 seconds)
    setInterval(nextImage, 5000);
  }

  // Initialize after the script loads
  initGallery();
</script>