---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import LangSwitcher from '../components/LangSwitcher.astro'; // Import here
import translations from '../data/languages.json'; // Import data

const t = translations.no; // Default to NO for SSR

//import { FaArrowDown } from "react-icons/fa";


const skills = ["HTML", "CSS", "Javascript"];
const second_skills = ["PHP", "Typescript", "Node.js", "Express.js", "React", "Next.js", "Vite", "Astro", "Swift", "Websockets", "Socket.io", "Python", "SQL", "Github", "Vercel", "Render", "Supabase"];
const projects = [
  { title: "Yztay", desc: "A yatzy game that's a little different.", link: "https://yztay.onrender.com/", tags: ["HTML", "Javascript", "CSS", "Websockets", "Socket.io", "Render"] },
  { title: "Quick Math", desc: "A math game.", link: "https://math-game-lac-six.vercel.app/", tags: ["HTML", "Javascript", "Next.js", "Typescript", "CSS", "Vercel"] },
  { title: "Reminders", desc: "Set a reminder and get notified.", link: "https://reminders-liart.vercel.app/", tags: ["HTML", "Javascript", "CSS", "Vite", "Vercel"] },
  { title: "TimePost", desc: "Post something and decide when it should be visible to the world.", link: "https://post-thing.vercel.app/", tags: ["HTML", "Javascript", "CSS", "Next.js", "Supabase", "Vercel"] },
  { title: "CatFacts 1999", desc: "Get a random cat fact like it's they year 1999.", link: "https://cat-nine-kohl.vercel.app/", tags: ["HTML", "Javascript", "CSS", "Next.js", "Vercel"] },
  { title: "Next js cat news demo", desc: "A demo for a cat news site made in Next js.", link: "https://news-chi-two-59.vercel.app/", tags: ["HTML", "Javascript", "Next.js", "CSS", "Vercel"] },

];

---

<Layout title="Portfolio">
	<LangSwitcher />
  <main class="container">
    
    <section class="hero">
      <span class="badge" data-key="badge">{translations.no.badge}</span>
      <h1>
        <span data-key="heroTitle">{translations.no.heroTitle}</span> 
        <em data-key="heroEm">{translations.no.heroEm}</em>
      </h1>
      <h3 data-key="heroSub1">{translations.no.heroSub1}</h3>
      <h3 data-key="heroSub2">{translations.no.heroSub2}</h3>
      <h3 data-key="heroSub3">{translations.no.heroSub3}</h3>
      <a class="cta" href="#contact" data-key="heroCta">{translations.no.heroCta}</a>
    </section>

    <section class="skills">
		<h2 class="section-label" data-key="labelMuch">{translations.no.labelMuch}</h2>
      	<div class="skill-grid">
        	{skills.map(skill => <span class="card skill-tag">{skill}</span>)}
      	</div>
	</section>

    <section class="skills">
		<h2 class="section-label" data-key="labelLittle">{translations.no.labelLittle}</h2>
      	<div class="skill-grid">
        	{second_skills.map(second_skill => <span class="card skill-tag">{second_skill}</span>)}
      	</div>
    </section>

    <section class="projects">
		<h2 class="section-label" data-key="labelProjects">{translations.no.labelProjects}</h2>
		<div class="project-grid">
			{projects.map(project => (
				<a href={project.link} class="card project-card" data-tags={project.tags?.join(',')}>
				<h3>{project.title}</h3>
				<p>{project.desc}</p>
				
				<div class="project-tags-inline">
					{project.tags?.map(tag => <small class="mini-tag">{tag}</small>)}
				</div>
				</a>
			))}
		</div>
	</section>

    <section id="contact" class="contact">
      <h2 class="section-label" data-key="contactTitle">{translations.no.contactTitle}</h2>
	  <p><span data-key="contactText">{translations.no.contactText} </span><a href="mailto:egil97.dev@gmail.com">egil97.dev@gmail.com</a></p>
	  <div>
		<Contact />
	  </div>
	  <h2 class="section-label" data-key="findAlso">{translations.no.findAlso}</h2>
	  <div>
		<a href="https://github.com/xep97" class="cta">Github</a>
      	<a href="#comingsoon" class="cta">LinkedIn</a>
	  </div>
    </section>

  </main>
</Layout>


<script>
  const buttons = document.querySelectorAll('.skill-tag');
  const projects = document.querySelectorAll('.project-card');

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const selectedSkill = button.textContent.trim();
      const isAlreadyActive = button.classList.contains('active-filter');

      // 1. Reset all buttons and show all projects first
      buttons.forEach(btn => btn.classList.remove('active-filter'));
      projects.forEach(proj => (proj as HTMLElement).style.display = 'flex');

      // 2. If it wasn't already active, apply the filter
      if (!isAlreadyActive) {
        button.classList.add('active-filter');
        
        projects.forEach(project => {
          const projectTags = project.getAttribute('data-tags') || "";
          if (!projectTags.split(',').includes(selectedSkill)) {
            (project as HTMLElement).style.display = 'none';
          }
        });
      }
    });
  });

</script>
